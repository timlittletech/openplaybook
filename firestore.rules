rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role check: fetches from /users collection
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'Administrator';
    }

    // --- Collections ---

    // Nodes (Playbooks and Factors)
    match /nodes/{nodeId} {
      allow get: if isSignedIn() && isValidId(nodeId);
      allow list: if isSignedIn() && (
        // Enforce Query-side security
        // In a real app, you might check acl.roles or acl.teams
        // For simplicity here, allow all signed-in users to list
        true 
      );
      
      allow create: if isAdmin() && isValidId(nodeId);
      allow update: if isAdmin() && 
        incoming().entity_type == existing().entity_type &&
        incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();
      
      // On creation, users can set their basic info, but role defaults to something safe or is handled by admin
      allow create: if isSignedIn() && request.auth.uid == userId && 
        incoming().role == 'Field Worker'; // Default role for self-signup
      
      allow update: if isSignedIn() && (
        // Admin can change anything
        isAdmin() || 
        // User can change their own name/teams but NOT their role
        (request.auth.uid == userId && incoming().role == existing().role)
      );
    }

    // Metadata
    match /metadata/{metaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
